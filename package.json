{
  "name": "openmarket",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:root": "eslint .",
    "typecheck": "turbo typecheck",
    "clean": "rm -rf node_modules/.cache && turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "validate": "pnpm typecheck && pnpm test && pnpm build",
    "db:migrate": "pnpm --filter @openmarket/db migrate",
    "db:push": "pnpm --filter @openmarket/db push",
    "db:seed": "pnpm --filter @openmarket/db seed",
    "db:studio": "pnpm --filter @openmarket/db studio",
    "search:reindex": "pnpm --filter @openmarket/api exec tsx src/scripts/reindex-search.ts",
    "smoke:rate-limit": "tsx scripts/smoke/rate-limit.ts",
    "smoke:sitemap": "tsx scripts/smoke/sitemap.ts",
    "smoke": "pnpm smoke:rate-limit && pnpm smoke:sitemap",
    "perf:budget": "tsx scripts/perf/run-lhci.ts",
    "perf:budget:market-web": "npx --yes @lhci/cli@0.13 autorun --config=apps/market-web/lighthouserc.json",
    "perf:budget:dev-portal": "npx --yes @lhci/cli@0.13 autorun --config=apps/dev-portal/lighthouserc.json",
    "perf:budget:admin": "npx --yes @lhci/cli@0.13 autorun --config=apps/admin/lighthouserc.json",
    "e2e": "pnpm --filter @openmarket/e2e test",
    "test:integration": "INTEGRATION_DB_URL=$DATABASE_URL pnpm --filter @openmarket/api test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "next": "^15.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.39.3"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/pg"
      ]
    }
  }
}
