{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && if [ \"$VERCEL_ENV\" = \"production\" ]; then pnpm --filter @openmarket/db migrate; fi && pnpm turbo build --filter=@openmarket/api^...",
  "regions": ["iad1"],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/cron/charts-recompute", "schedule": "0 * * * *" },
    { "path": "/api/cron/statistics-recompute", "schedule": "15 0 * * *" },
    { "path": "/api/cron/reviews-promote-due", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/reviews-detect-bombs", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/dmca-restore-due", "schedule": "30 1 * * *" },
    { "path": "/api/cron/payouts-run", "schedule": "0 2 1 * *" },
    { "path": "/api/cron/accounts-hard-delete", "schedule": "0 3 * * *" }
  ]
}
