# OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# API
PORT=3001

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001
